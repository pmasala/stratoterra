{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stratoterra.io/schemas/country_summary_schema.json",
  "title": "CountrySummary",
  "description": "Schema for all_countries_summary.json — accepts both a bare array and a wrapper object with a 'countries' array.",
  "oneOf": [
    {
      "type": "array",
      "items": { "$ref": "#/definitions/CountrySummaryItem" },
      "minItems": 1
    },
    {
      "type": "object",
      "required": ["countries"],
      "additionalProperties": true,
      "properties": {
        "generated_at": { "type": "string" },
        "run_id": { "type": "string" },
        "countries": {
          "type": "array",
          "items": { "$ref": "#/definitions/CountrySummaryItem" },
          "minItems": 1
        }
      }
    }
  ],
  "definitions": {
    "CountrySummaryItem": {
      "type": "object",
      "title": "CountrySummaryItem",
      "required": [
        "code",
        "name",
        "region",
        "tier",
        "last_updated"
      ],
      "additionalProperties": true,
      "properties": {
        "code": {
          "type": "string",
          "description": "ISO 3166-1 alpha-3 country code",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$"
        },
        "name": {
          "type": "string",
          "description": "Country display name",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "description": "Geopolitical region classification",
          "enum": [
            "north_america",
            "latin_america",
            "europe",
            "middle_east",
            "sub_saharan_africa",
            "south_asia",
            "east_asia",
            "southeast_asia",
            "central_asia",
            "oceania"
          ]
        },
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "gdp_nominal_usd": {
          "type": "number",
          "minimum": 0
        },
        "gdp_real_growth_pct": {
          "type": "number"
        },
        "last_updated": {
          "type": "string"
        }
      }
    }
  }
}
