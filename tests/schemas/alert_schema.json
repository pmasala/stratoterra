{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stratoterra.io/schemas/alert_schema.json",
  "title": "AlertIndex",
  "description": "Schema for data/indices/alert_index.json — the master list of active alerts.",
  "type": "object",
  "required": [
    "alerts"
  ],
  "additionalProperties": true,
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when this index was generated"
    },
    "last_updated": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "total_count": {
      "type": "integer",
      "minimum": 0
    },
    "alerts": {
      "type": "array",
      "description": "Array of active alerts",
      "items": {
        "type": "object",
        "required": [
          "alert_id",
          "severity"
        ],
        "additionalProperties": true,
        "properties": {
          "alert_id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "watch"]
          },
          "title": {
            "type": "string"
          },
          "headline": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "country_code": {
            "type": "string",
            "pattern": "^[A-Z]{3}$"
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "affected_factors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["new", "ongoing", "escalated", "deescalated", "resolved", "updated"]
          },
          "first_triggered": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "last_updated": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        }
      }
    }
  }
}
