{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stratoterra.io/schemas/alert_schema.json",
  "title": "AlertIndex",
  "description": "Schema for data/indices/alert_index.json — the master list of active alerts.",
  "type": "object",
  "required": [
    "alerts"
  ],
  "additionalProperties": true,
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when this index was generated",
      "format": "date-time"
    },
    "schema_version": {
      "type": "string"
    },
    "total_count": {
      "type": "integer",
      "minimum": 0
    },
    "alerts": {
      "type": "array",
      "description": "Array of active alerts",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "title",
          "description",
          "type",
          "countries"
        ],
        "additionalProperties": true,
        "properties": {
          "alert_id": {
            "type": "string",
            "description": "Unique identifier for this alert",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "description": "Alert severity level",
            "enum": ["critical", "warning", "watch"]
          },
          "title": {
            "type": "string",
            "description": "Short alert title",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Full alert description",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "description": "Category / type of alert (e.g. political_instability, economic_shock, military_escalation)",
            "minLength": 1
          },
          "countries": {
            "type": "array",
            "description": "ISO 3166-1 alpha-3 codes of countries affected by this alert",
            "items": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "minItems": 1
          },
          "factors_affected": {
            "type": "array",
            "description": "Factor paths that triggered or are relevant to this alert",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "description": "Alert lifecycle status",
            "enum": ["new", "ongoing", "escalated", "deescalated", "resolved"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
