{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stratoterra.io/schemas/manifest_schema.json",
  "title": "ChunkManifest",
  "description": "Schema for data/chunks/manifest.json — the index of all UI-served chunk files.",
  "type": "object",
  "required": [
    "generated_at",
    "files"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version string, e.g. '1.0'"
    },
    "run_id": {
      "type": "string",
      "description": "Pipeline run identifier"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when this manifest was generated"
    },
    "files": {
      "description": "Chunk files listed as an array of entries or a dict keyed by category",
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "additionalProperties": true,
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "last_modified": { "type": "string" },
              "size_bytes": { "type": "integer", "minimum": 0 }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    }
  }
}
