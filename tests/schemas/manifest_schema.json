{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stratoterra.io/schemas/manifest_schema.json",
  "title": "ChunkManifest",
  "description": "Schema for data/chunks/manifest.json — the index of all UI-served chunk files.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "files"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version string, e.g. '1.0'",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when this manifest was generated",
      "format": "date-time"
    },
    "pipeline_run_date": {
      "type": "string",
      "description": "ISO 8601 date of the pipeline run that produced these chunks"
    },
    "total_files": {
      "type": "integer",
      "description": "Total number of chunk files listed",
      "minimum": 0
    },
    "files": {
      "type": "array",
      "description": "List of all chunk files available for the UI",
      "items": {
        "type": "object",
        "required": [
          "path",
          "last_modified",
          "size_bytes"
        ],
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path of the chunk file from the data/chunks/ root",
            "minLength": 1
          },
          "last_modified": {
            "type": "string",
            "description": "ISO 8601 UTC timestamp of when the file was last modified",
            "format": "date-time"
          },
          "size_bytes": {
            "type": "integer",
            "description": "File size in bytes",
            "minimum": 0
          },
          "content_type": {
            "type": "string",
            "description": "MIME type, typically application/json"
          },
          "etag": {
            "type": "string",
            "description": "Optional content hash / ETag for cache busting"
          }
        }
      }
    },
    "summary_chunk": {
      "type": "object",
      "description": "Quick reference to the all_countries_summary chunk",
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "country_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
