# =============================================================================
# Stratoterra API Keys Configuration
# Copy this file to .env and fill in your keys.
# The .env file is in .gitignore and will never be committed.
# All sources below are free tier.
# =============================================================================

# ---------------------------------------------------------------------------
# UN Comtrade API (free tier: 100 requests/hour)
# Register at: https://comtradeplus.un.org/
# ---------------------------------------------------------------------------
UN_COMTRADE_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# ACLED (Armed Conflict Location & Event Data)
# Free for non-commercial use. Register at: https://acleddata.com/
# ---------------------------------------------------------------------------
ACLED_API_KEY=your_key_here
ACLED_EMAIL=your_email@example.com

# ---------------------------------------------------------------------------
# EIA (U.S. Energy Information Administration)
# Free API. Register at: https://www.eia.gov/opendata/
# ---------------------------------------------------------------------------
EIA_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# ExchangeRate-API
# Free tier: 1,500 requests/month. Register at: https://www.exchangerate-api.com/
# ---------------------------------------------------------------------------
EXCHANGERATE_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# GDELT Project (no key required — public API)
# ---------------------------------------------------------------------------
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc

# ---------------------------------------------------------------------------
# World Bank API (no key required — public API)
# ---------------------------------------------------------------------------
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# ---------------------------------------------------------------------------
# IMF Data API (no key required — public API)
# ---------------------------------------------------------------------------
IMF_API_URL=https://www.imf.org/external/datamapper/api/v1

# ---------------------------------------------------------------------------
# UN Data API (no key required — public API)
# ---------------------------------------------------------------------------
UN_DATA_API_URL=https://data.un.org/ws/rest

# ---------------------------------------------------------------------------
# Optional: Proxy settings for web fetching (if behind a firewall)
# ---------------------------------------------------------------------------
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ---------------------------------------------------------------------------
# Pipeline settings (override defaults if needed)
# ---------------------------------------------------------------------------
# PIPELINE_DATE_OVERRIDE=2026-03-01   # Force a specific date instead of today
# PIPELINE_TIER_FILTER=1,2            # Only process Tier 1 and 2 countries
# PIPELINE_DRY_RUN=false              # Set to true to skip writing /data/
