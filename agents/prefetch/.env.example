# Stratoterra Pre-Fetch API Keys
# Copy to .env and fill in values. All are free-tier.

# ACLED — https://acleddata.com/ (free registration, OAuth 2.0)
ACLED_EMAIL=
ACLED_PASSWORD=

# US EIA — https://www.eia.gov/opendata/register.php (free)
EIA_API_KEY=

# ExchangeRate-API — https://www.exchangerate-api.com/ (free tier: 1500 req/month)
EXCHANGERATE_API_KEY=

# UN Comtrade — https://comtradeplus.un.org/ (free registration)
COMTRADE_API_KEY=
