{
  "id": "agent_09",
  "name": "Data Integrator",
  "phase": 4,
  "phase_name": "INTEGRATE",
  "description": "Merges all ACCEPTED, ACCEPT_WITH_NOTE, and FLAGGED updates from the validator into the main /data/ store. Updates timeseries history, timestamps, and metadata. Does not touch REJECTED or unresolved ESCALATED items.",
  "inputs": [
    "staging/validated/validated_updates_{DATE}.json",
    "data/countries/*.json",
    "data/relations/*.json",
    "data/timeseries/*.json"
  ],
  "outputs": [
    "data/countries/*.json",
    "data/relations/*.json",
    "data/timeseries/*.json",
    "data/metadata/last_update.json",
    "data/metadata/update_log.json"
  ],
  "timeout_minutes": 10,
  "accepted_verdicts": ["ACCEPT", "ACCEPT_WITH_NOTE", "FLAG"],
  "rejected_verdicts": ["REJECT"],
  "flag_handling": "add_to_metadata.active_flags_array",
  "timeseries_policy": "append_previous_value_before_overwrite",
  "prerequisite_agent": "agent_08",
  "prerequisite_condition": "auditor_escalation_review_complete",
  "retry_on_failure": false,
  "idempotent": true,
  "prompt_file": "agents/prompts/agent_09_integrator.md"
}
