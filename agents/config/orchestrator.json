{
  "id": "orchestrator",
  "name": "Master Pipeline Orchestrator",
  "phase": 0,
  "phase_name": "ORCHESTRATION",
  "description": "Controls the sequential execution of all 16 agents in the weekly update pipeline. Manages the run log, handles human review pauses, and coordinates error recovery.",
  "inputs": [
    "data/indices/country_list.json",
    "data/metadata/last_update.json",
    "agents/config/agent_01_official_stats.json",
    "agents/config/agent_02_financial_data.json",
    "agents/config/agent_03_news_events.json",
    "agents/config/agent_04_trade_sanctions.json",
    "agents/config/agent_05_military_conflict.json",
    "agents/config/agent_06_political_regulatory.json",
    "agents/config/agent_07_processor.json",
    "agents/config/agent_08_validator.json",
    "agents/config/agent_09_integrator.json",
    "agents/config/agent_10_trends.json",
    "agents/config/agent_11_derived_metrics.json",
    "agents/config/agent_12_alerts.json",
    "agents/config/agent_13_narratives.json",
    "agents/config/agent_14_briefing.json",
    "agents/config/agent_15_quality.json",
    "agents/config/agent_16_archive.json"
  ],
  "outputs": [
    "staging/run_log.json"
  ],
  "timeout_minutes": 300,
  "human_review_points": [
    {
      "after_agent": "agent_08",
      "condition": "escalated_items > 0",
      "action": "PAUSE and present escalation_report to operator"
    },
    {
      "after_agent": "agent_15",
      "condition": "always",
      "action": "PAUSE and present quality_report to operator before archiving"
    }
  ],
  "pipeline_sequence": [
    "agent_01", "agent_02", "agent_03", "agent_04", "agent_05", "agent_06",
    "agent_07",
    "agent_08",
    "agent_09",
    "agent_10", "agent_11", "agent_12",
    "agent_13", "agent_14",
    "agent_15",
    "agent_16"
  ],
  "error_handling": "stop_on_failure",
  "retry_on_failure": false,
  "idempotent": false
}
