# Pre-fetch cache (local fallback, not committed)
staging/prefetch_cache/

# Large archive snapshots (keep in git history, not working tree)
# archive/

# Test reports (regenerated)
tests/reports/

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/
